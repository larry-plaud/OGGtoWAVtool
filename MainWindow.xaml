<Window x:Class="OggConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OGG → MP3 Converter"
        Width="860" Height="640" MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F13">

    <Window.Resources>
        <!-- Brushes -->
        <SolidColorBrush x:Key="BgDark"      Color="#0F0F13"/>
        <SolidColorBrush x:Key="BgCard"      Color="#17171F"/>
        <SolidColorBrush x:Key="BgHover"     Color="#1E1E2A"/>
        <SolidColorBrush x:Key="BrBorder"    Color="#2A2A3A"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#7C6FFF"/>
        <SolidColorBrush x:Key="AccentPink"  Color="#FF6F91"/>
        <SolidColorBrush x:Key="TxtMain"     Color="#F0EEF8"/>
        <SolidColorBrush x:Key="TxtMuted"    Color="#6B6882"/>

        <!-- CheckBox (global) -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TxtMuted}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ListBox (global) -->
        <Style TargetType="ListBox">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- IconButton -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderBrush"    Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"     Value="{StaticResource TxtMain}"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Padding"        Value="10,6"/>
            <Setter Property="FontSize"       Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="{StaticResource BgHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentPurple}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2A3A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PrimaryButton -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="28,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C6FFF" Offset="0"/>
                                    <GradientStop Color="#A855F7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DangerButton -->
        <Style x:Key="DangerButton" TargetType="Button"
               BasedOn="{StaticResource IconButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#F87171"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- FolderListBoxItem -->
        <Style x:Key="FolderLBI" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TxtMain}"/>
            <Setter Property="Padding"    Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{StaticResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#252535"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- LogListBoxItem -->
        <Style x:Key="LogLBI" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="6,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0"
                Background="#17171F"
                BorderBrush="{StaticResource BrBorder}"
                BorderThickness="0,0,0,1"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="30" Height="30" CornerRadius="8" Margin="0,0,12,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C6FFF" Offset="0"/>
                                <GradientStop Color="#FF6F91" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="♫" FontSize="15" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="OGG → WAV Converter"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource TxtMain}"/>
                        <TextBlock Text="批量音频格式转换工具"
                                   FontSize="11" Foreground="{StaticResource TxtMuted}"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Bitrate -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="比特率："
                               Foreground="{StaticResource TxtMuted}"
                               VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                    <ComboBox x:Name="BitrateCombo" Width="100" Height="28" FontSize="12"
                              Foreground="{StaticResource TxtMain}"
                              BorderBrush="{StaticResource BrBorder}">
                        <ComboBoxItem Content="128 kbps"/>
                        <ComboBoxItem Content="192 kbps" IsSelected="True"/>
                        <ComboBoxItem Content="256 kbps"/>
                        <ComboBoxItem Content="320 kbps"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ BODY ══ -->
        <Grid Grid.Row="1" Margin="18,14,18,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- LEFT label -->
            <StackPanel Grid.Column="0" Grid.Row="0"
                        Orientation="Horizontal" Margin="0,0,0,6">
                <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                        Background="#7C6FFF22">
                    <TextBlock Text="源文件夹" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentPurple}"/>
                </Border>
                <TextBlock x:Name="FolderCountText" Text="0 个文件夹"
                           FontSize="11" Foreground="{StaticResource TxtMuted}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="FileCountText" Text=""
                           FontSize="11" Foreground="{StaticResource TxtMuted}"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- LEFT card -->
            <Border Grid.Column="0" Grid.Row="1"
                    Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource BrBorder}"
                    BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="FolderListBox" Grid.Row="0"
                             Padding="8,6,8,0"
                             ItemContainerStyle="{StaticResource FolderLBI}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="📁" FontSize="14"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                                   Foreground="{StaticResource TxtMain}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding FullPath}" FontSize="10"
                                                   Foreground="{StaticResource TxtMuted}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" CornerRadius="10"
                                            Padding="6,2" Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Background="#7C6FFF22">
                                        <TextBlock Text="{Binding OggCount}" FontSize="10"
                                                   Foreground="{StaticResource AccentPurple}"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty state hint -->
                    <StackPanel x:Name="EmptyHint" Grid.Row="0"
                                IsHitTestVisible="False"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📂" FontSize="36"
                                   HorizontalAlignment="Center" Opacity="0.25"/>
                        <TextBlock Text="点击下方按钮添加文件夹" FontSize="12"
                                   Foreground="{StaticResource TxtMuted}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Folder buttons -->
                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource BrBorder}"
                            BorderThickness="0,1,0,0" Padding="8,8">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="AddFolderBtn"
                                    Style="{StaticResource IconButton}"
                                    Click="AddFolder_Click" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="＋" FontSize="13" Margin="0,0,4,0"/>
                                    <TextBlock Text="添加文件夹" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="RemoveFolderBtn"
                                    Style="{StaticResource DangerButton}"
                                    Click="RemoveFolder_Click" IsEnabled="False">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✕" FontSize="11" Margin="0,0,4,0"/>
                                    <TextBlock Text="移除" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="ClearFoldersBtn"
                                    Style="{StaticResource DangerButton}"
                                    Click="ClearFolders_Click"
                                    Margin="6,0,0,0" IsEnabled="False">
                                <TextBlock Text="清空" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- RIGHT label -->
            <StackPanel Grid.Column="2" Grid.Row="0"
                        Orientation="Horizontal" Margin="0,0,0,6">
                <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                        Background="#FF6F9122">
                    <TextBlock Text="输出设置 &amp; 日志" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentPink}"/>
                </Border>
            </StackPanel>

            <!-- RIGHT card -->
            <Border Grid.Column="2" Grid.Row="1"
                    Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource BrBorder}"
                    BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Output folder section -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BrBorder}"
                            BorderThickness="0,0,0,1" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="输出文件夹" FontSize="11"
                                       Foreground="{StaticResource TxtMuted}"
                                       Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        BorderBrush="{StaticResource BrBorder}"
                                        BorderThickness="1" CornerRadius="6" Padding="8,6">
                                    <Border.Background>
                                        <SolidColorBrush Color="#0F0F13"/>
                                    </Border.Background>
                                    <TextBlock x:Name="OutputPathText"
                                               Text="（未选择，保存到源文件夹旁）"
                                               FontSize="11"
                                               Foreground="{StaticResource TxtMuted}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <Button Grid.Column="1" x:Name="BrowseOutputBtn"
                                        Style="{StaticResource IconButton}"
                                        Click="BrowseOutput_Click"
                                        Margin="6,0,0,0" Padding="10,6">
                                    <TextBlock Text="浏览…" FontSize="12"/>
                                </Button>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <CheckBox x:Name="KeepStructureCheck"
                                          Content="保留子目录结构"
                                          IsChecked="True" Margin="0,0,16,0"/>
                                <CheckBox x:Name="OverwriteCheck"
                                          Content="覆盖已有文件"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Log section -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal" Margin="12,7,12,4">
                            <TextBlock Text="转换日志" FontSize="11"
                                       Foreground="{StaticResource TxtMuted}"/>
                            <Button x:Name="ClearLogBtn"
                                    Style="{StaticResource IconButton}"
                                    Click="ClearLog_Click"
                                    BorderThickness="0" Padding="4,0"
                                    Margin="8,0,0,0" Height="14">
                                <TextBlock Text="清空" FontSize="10"
                                           Foreground="{StaticResource TxtMuted}"/>
                            </Button>
                        </StackPanel>
                        <ListBox x:Name="LogListBox" Grid.Row="1"
                                 Padding="8,0,8,8"
                                 ItemContainerStyle="{StaticResource LogLBI}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 FontFamily="Consolas" FontSize="11">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Prefix}"
                                                   Foreground="{Binding Color}"/>
                                        <TextBlock Text="{Binding Message}"
                                                   Foreground="{Binding Color}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ BOTTOM BAR ══ -->
        <Border Grid.Row="2"
                Background="#17171F"
                BorderBrush="{StaticResource BrBorder}"
                BorderThickness="0,1,0,0"
                Padding="18,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Progress area -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,18,0">
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="StatusText"
                                   Text="就绪 — 添加文件夹后点击【开始转换】"
                                   FontSize="12" Foreground="{StaticResource TxtMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="ProgressText" Grid.Column="1" Text=""
                                   FontSize="12" Foreground="{StaticResource AccentPurple}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <!-- Progress track -->
                    <Border x:Name="ProgressTrack" Height="6" CornerRadius="3"
                            SizeChanged="ProgressTrack_SizeChanged">
                        <Border.Background>
                            <SolidColorBrush Color="#1E1E2A"/>
                        </Border.Background>
                        <Border x:Name="ProgressFill" Height="6" CornerRadius="3"
                                HorizontalAlignment="Left" Width="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#7C6FFF" Offset="0"/>
                                    <GradientStop Color="#FF6F91" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="CancelBtn" Style="{StaticResource IconButton}"
                            Click="Cancel_Click" IsEnabled="False"
                            Margin="0,0,10,0" Padding="16,9">
                        <TextBlock Text="取消" FontSize="13"/>
                    </Button>
                    <Button x:Name="ConvertBtn" Style="{StaticResource PrimaryButton}"
                            Click="Convert_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶  " FontSize="13"/>
                            <TextBlock Text="开始转换" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
